# ─────────────────────────────────────────────
# MealBot 환경변수
# ─────────────────────────────────────────────
# Vite 프로젝트는 VITE_ 접두사가 붙은 변수만 클라이언트 코드에서 접근 가능
# 접두사 없는 변수는 빌드 도구(Vite) 내부에서만 사용됨
#
# 로컬 전용 민감 값(실제 서버 주소, API 키 등)은
# .env.local 파일에 작성할 것 → git에서 자동 제외됨
# ─────────────────────────────────────────────

# Spring Boot 백엔드 서버 주소
VITE_API_BASE_URL=http://localhost:8080

# AWS Spring 사용 시 위 줄 주석 처리해제
# VITE_API_BASE_URL=http://54.116.124.19:8080
# KT클라우드 Spring 사용 시 위 줄 주석 처리해제
# VITE_API_BASE_URL=http://